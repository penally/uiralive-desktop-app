# Discord Rich Presence - create app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_application_id_here

# Frontend URL - dev: http://localhost:5173, packaged: https://uira.live
# FRONTEND_URL=https://uira.live

# Update server URL - app checks here for updates. Default: http://localhost:8080
# Run "npm run serve:updates" to serve the out folder, then the app will find updates
UPDATE_SERVER_URL=http://localhost:8080
