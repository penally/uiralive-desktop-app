# Frontend Environment Variables
# Add your environment variables here
# Note: Variables prefixed with VITE_ are exposed to the client

# API Configuration
# Used by vite.config.ts as dev-server proxy target AND by runtime JS (config.backend.baseUrl)
# for direct requests that bypass the proxy (e.g. auth/login).
VITE_API_BASE_URL=http://localhost:3001

# TMDB API Configuration
# Get your API key from https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=32ffe2cb91e14b05b14faa4a6ed8ccc8
# WASM server-decrypted. X8-X13=XOR-encoded lease keys, X14+X18=split proof, X15-X16=path
VITE_WASM_LEASE=true
VITE_X8=fWJbdk7+T7UTHEE=
VITE_X9=aPSkoq1NG4nO0A==
VITE_X10=b05MfSSFZRHESM0=
VITE_X11=vg0K7l1n9+m310I=
VITE_X12=mr/tw0fx2kbWHA==
VITE_X13=mvSkA6Z8ngfMrR0=
VITE_X14=/EVItTPV0YXHrB8RUua8lQ==
VITE_X18=psH5wkvfP22C8pvhegfy6Q==
VITE_X15=OThmMGQwMzMwOQ==
VITE_X16=MjAwZGE0NmI0Mw==
VITE_USE_PROXY=true

# Pasmells Turnstile (Cloudflare) - invisible verification for /api/server
VITE_PASMELLS_TURNSTILE_SITE_KEY=0x4AAAAAACkazrput-ggdDtt
