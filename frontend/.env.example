# WASM double encryption - opaque env names (VITE_X0..X16)
# Run: node frontend/scripts/gen-all-secrets.mjs (backend + frontend)
# Run: node frontend/scripts/gen-wasm-path.mjs for VITE_X15, VITE_X16
# WASM_EXPIRY_DAYS=90
# VITE_USE_PROXY=true - use relative URLs for lease/WASM (Vite proxy forwards to backend)
# Index: X0-X7=wasm keys, X8-X13=XOR-encoded lease keys (need proof to decode), X14+X18=split proof, X15-X16=path

# Pasmells Turnstile (Cloudflare) - invisible verification for /api/server
# VITE_PASMELLS_TURNSTILE_SITE_KEY=your-pasmells-turnstile-site-key
