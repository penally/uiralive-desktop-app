# Database
DATABASE_URL="postgresql://username:password@localhost:5432/uira_live"

# JWT Secret
JWT_SECRET="your-secret-key-here"

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY="your-turnstile-secret-key"

# Server
PORT=3001

# Image Upload Service (Zipline)
ZIPLINE_URL=https://cdn.uira.live/api/upload
ZIPLINE_COOKIE=your-zipline-session-cookie-here

# Pasmells + BalooPow + Turnstile
PASMELLS_BASE_URL=https://pasmells.uira.live
APP_ORIGIN=https://beta.uira.live
PASMELLS_TURNSTILE_SECRET_KEY=your-pasmells-turnstile-secret-key
PASMELLS_BYPASS_KEY=c0717bc9b408fcf5688ac73f959ab511
BALOOPOW_API_URL=https://pow-api.bxv.gg
BALOOPOW_SECRET_KEY=your-baloo-secret-key
BALOOPOW_IDENTIFIER=uira-pasmells
BALOOPOW_AUTH_IDENTIFIER=uira-auth
# PASMELLS_PATH_KEY_P1..P4 - run: node backend/scripts/gen-pasmells-path-key.mjs (optional, for AES path segments)

# Browser fingerprint gate (generate with: node -e "require('crypto').randomBytes(32).toString('hex')|0" )
# FP_TOKEN_SECRET    — signs the short-lived token issued by /api/fp/register
# SESSION_BINDING_SECRET — proves a PoW challenge was created through the fp gate
FP_TOKEN_SECRET=generate-32-random-bytes-as-hex
SESSION_BINDING_SECRET=generate-32-random-bytes-as-hex

# WASM server-decrypted (keys never leave backend)
# WASM_LEASE_SECRET, WASM_PATH_SEG1, WASM_PATH_SEG2 - run gen-wasm-path.mjs
# LEASE_PROOF_SECRET - run gen-lease-proof.mjs
# WASM_ENCRYPT_KEY_P1..P4, WASM_ENCRYPT_KEY_2_P1..P4 - for server-side decrypt (gen-all-secrets.mjs)
# LEASE_RESPONSE_KEY_P1..P4, LEASE_RESPONSE_KEY_2_P1..P4 - for encrypted lease response (gen-lease-only.mjs or gen-all-secrets.mjs)
