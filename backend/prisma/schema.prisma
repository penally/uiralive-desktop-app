// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

enum MediaType {
  MOVIE
  SERIES
}

model User {
  id               Int              @id @default(autoincrement())
  email            String           @unique
  username         String?
  password         String
  avatar           String?
  isAdmin          Boolean          @default(false)
  isOwner          Boolean          @default(false)
  isApproved       Boolean          @default(false)
  commentBlocked   Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  watchlistItems   WatchlistItem[]
  watchProgress    WatchProgress[]
  playerSettings   PlayerSettings?
  sessions         Session[]
  comments         Comment[]
}

model Comment {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId    Int
  type      MediaType
  season    Int       @default(0)
  episode   Int       @default(0)
  content   String
  createdAt DateTime  @default(now())

  @@unique([userId, tmdbId, type, season, episode])
}

model LockedContent {
  id        Int      @id @default(autoincrement())
  tmdbId    Int
  type      MediaType
  season    Int?
  episode   Int?
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id         String   @id @default(uuid())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName String
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @updatedAt
}

model WatchProgress {
  id           Int       @id @default(autoincrement())
  userId       Int
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaKey     String    // "{tmdbId}_{type}" for movies, "{tmdbId}_{type}_{season}_{episode}" for TV
  tmdbId       Int
  type         MediaType
  season       Int?
  episode      Int?
  progress     Float
  duration     Float
  title        String?
  posterPath   String?
  backdropPath String?
  voteAverage  Float?
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())

  @@unique([userId, mediaKey])
}

model PlayerSettings {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtitleSize       Float?
  subtitleColor      String?
  subtitleBackground String?
  subtitleBgOpacity  Float?
  subtitleShadow     String?
  subtitleBgEnabled  Boolean?
  subtitleAutoDetect Boolean?
  subtitleOpacity    Float?
  subtitleFontFamily String?
  subtitleFontWeight String?
  subtitleFontStyle  String?
  subtitleTextDecoration String?
  subtitleDelay      Float?
  fixSubtitles       Boolean?
  fixCapitalization  Boolean?
  volume             Float?
  playbackRate       Float?
  autoQuality        Boolean?
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())
}

model Media {
  id         Int         @id @default(autoincrement())
  tmdbId     Int
  type       MediaType
  title      String
  year       Int?
  posterPath String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  watchlistItems WatchlistItem[]
  @@unique([tmdbId, type])
}

model WatchlistItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaId   Int
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  addedAt   DateTime @default(now())
  @@unique([userId, mediaId])
}
